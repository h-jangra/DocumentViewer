{
  "manifest_version": 3,
  "name": "Document Viewer",
  "version": "1.1",
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["script.js"]
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "viewer.html",
        "viewer.js",
        "mammoth.min.js",
        "xlsx.min.js",
        "jszip.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
